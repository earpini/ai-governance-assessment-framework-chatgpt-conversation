            }

            .firstnumber {
                  color: #000000;
                  position: absolute;
                  top: 50px;
                  right: 90px;
                  font-size: 30px;
            }

            .secondnumber {
                  position: absolute;
                  color: #000000;
                  right: 45px;
                  top: 50px;
                  font-size: 30px;
            }

            .countdown .days {
                  font-size: 35px;
                  color: gold;
